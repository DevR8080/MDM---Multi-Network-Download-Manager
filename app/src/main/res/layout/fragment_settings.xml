<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginBottom="?android:actionBarSize"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/settingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/ItemBG"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:text="Download location"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dirLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/StatsItem"
                    android:text="System Downloads (default)" />

                <Button
                    android:id="@+id/btnChangeDir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/CancelButton"
                    android:layout_marginTop="10dp"
                    android:text="Change location" />

                <Button
                    android:id="@+id/btnResetDir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:backgroundTint="@color/StartButton"
                    android:text="Reset to default" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Network settings card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/ItemBG"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@android:color/white"
                        android:text="Use both networks" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchUseBoth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@android:color/white"
                    android:text="Wi-Fi sessions" />

                <SeekBar
                    android:id="@+id/seekWifi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/StartButton"
                    android:progressBackgroundTint="@color/StartButton"
                    android:thumbTint="@color/StartButton"
                    android:max="16" />

                <TextView
                    android:id="@+id/seekWifiVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/StatsItem"
                    android:text="8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@android:color/white"
                    android:text="Cellular sessions" />

                <SeekBar
                    android:id="@+id/seekCell"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/StartButton"
                    android:progressBackgroundTint="@color/StartButton"
                    android:thumbTint="@color/StartButton"
                    android:max="16" />

                <TextView
                    android:id="@+id/seekCellVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/StatsItem"
                    android:text="8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@android:color/white"
                    android:text="Wi-Fi quota per download (GB, 0 = unlimited)" />

                <EditText
                    android:id="@+id/inputWifiQuotaGb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/StatsItem"
                    android:textColorHint="@color/StatsItem"
                    android:textSize="15sp"
                    android:hint="@string/_0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@android:color/white"
                    android:text="Cellular quota per download (GB, 0 = unlimited)" />

                <EditText
                    android:id="@+id/inputCellQuotaGb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/StatsItem"
                    android:textColorHint="@color/StatsItem"
                    android:textSize="15sp"
                    android:hint="@string/_0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@android:color/white"
                    android:text="Max retries" />

                <EditText
                    android:id="@+id/inputMaxRetries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/StatsItem"
                    android:textColorHint="@color/StatsItem"
                    android:textSize="15sp"
                    android:hint="@string/_3" />

                <Button
                    android:id="@+id/btnSaveLimits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/StartButton"
                    android:text="Save" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
