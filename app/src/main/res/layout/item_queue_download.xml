<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/deleteCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/ItemBG"
        app:cardCornerRadius="17dp"
        app:cardElevation="5dp">

        <RelativeLayout
            android:id="@+id/bgPane"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@android:color/holo_red_dark"
            android:paddingEnd="8dp"
            android:paddingStart="8dp">

            <LinearLayout
                android:id="@+id/deleteAction"
                android:layout_width="65dp"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:background="@android:color/holo_red_dark">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/trash"
                    app:tint="@android:color/white"
                    android:contentDescription="@string/delete"/>
            </LinearLayout>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/foregroundCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/ItemBG"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:padding="12dp">

            <!-- Left: fixed-size file icon -->
            <ImageView
                android:id="@+id/fileIcon"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_alignParentStart="true"
                android:contentDescription="@string/file_icon"
                android:scaleType="centerInside"
                android:src="@drawable/file"
                app:tint="@color/selected" />

            <!-- Right column (percent + circular progress) -->
            <LinearLayout
                android:id="@+id/rightCol"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/fileProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@android:color/holo_green_light"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- determinate circular progress (only this view uses Material) -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/fileProgressCircle"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginTop="6dp"
                    app:indicatorColor="@android:color/holo_green_light"
                    app:indicatorSize="26dp"
                    app:trackColor="@android:color/darker_gray"
                    app:trackThickness="3dp" />
            </LinearLayout>

            <!-- Middle: name constrained between icon and right column -->
            <TextView
                android:id="@+id/fileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_toStartOf="@id/rightCol"
                android:layout_toEndOf="@id/fileIcon"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="MyFile.zip"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Status below name, also constrained to the right column -->
            <TextView
                android:id="@+id/fileStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/fileName"
                android:layout_alignStart="@id/fileName"
                android:layout_toStartOf="@id/rightCol"
                android:ellipsize="end"
                android:maxLines="2"
                android:lineSpacingExtra="2dp"
                android:text="Downloading..."
                android:textColor="@color/MenuItems"
                android:textSize="13sp" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>